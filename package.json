{
  "name": "calorie-tracker",
  "version": "1.0.3",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "check": "node --check server.js",
    "test": "node --test test/*.test.mjs",
    "smoke": "node scripts/smoke-test.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "export": "node scripts/export-data.mjs",
    "import": "node scripts/import-data.mjs"
  },
  "dependencies": {
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1"
  },
  "description": "Shared calorie and weight tracker with Express, SQLite, Docker, and an assistant-friendly API.",
  "engines": {
    "node": ">=22 <25"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "prettier": "^3.6.2"
  }
}
